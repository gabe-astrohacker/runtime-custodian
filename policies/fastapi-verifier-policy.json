{
  "workload_id": "fastapi-echo",
  "profile_mode": "minimal-behaviour",
  "acceptable": {
    "exec_paths": [
      "/usr/local/bin/python",
      "/usr/bin/echo"
    ],
    "event_types": [
      "fork"
    ]
  },
  "suspicious": {
    "unknown_exec_path": true
  },
  "denied": {
    "exec_paths": [
      "/usr/bin/id",
      "/bin/sh",
      "/bin/bash",
      "/usr/bin/curl",
      "/usr/bin/wget",
      "/bin/nc",
      "/usr/bin/nc"
    ],
    "comm_names": [
      "id",
      "sh",
      "bash",
      "curl",
      "wget",
      "nc"
    ]
  },
  "attestation": {
    "backend": "none",
    "mode": "software-chain",
    "fail_on_suspicious": false,
    "fail_on_denied": true,
    "fail_on_drops": true
  }
}
